# .env.example
# Copy this file to .env and fill in your real values.
# NEVER commit .env to GitHub - it contains secrets!
# .env.example IS safe to commit - it's a template with no real values.

# ─── DATABASE ─────────────────────────────────────────────────────────────────
# Format: mysql+pymysql://USERNAME:PASSWORD@HOST:PORT/DATABASE_NAME
# 
# For Railway MySQL:
# DATABASE_URL=mysql+pymysql://root:yourpassword@containers-us-west-xxx.railway.app:6543/railway
#
# For local MySQL:
# DATABASE_URL=mysql+pymysql://root:yourpassword@localhost:3306/userdb
DATABASE_URL=mysql+pymysql://username:password@hostname:port/database_name

# ─── JWT AUTHENTICATION ────────────────────────────────────────────────────────
# SECRET_KEY: A long random string used to sign JWT tokens.
# Generate one with: python -c "import secrets; print(secrets.token_hex(32))"
# NEVER share this key or commit the real value!
SECRET_KEY=your-super-secret-key-minimum-32-characters-long-change-this

# JWT signing algorithm - HS256 is the industry standard for API tokens
ALGORITHM=HS256

# How many minutes until the JWT access token expires
# 30 minutes is a good default for security
ACCESS_TOKEN_EXPIRE_MINUTES=30

# ─── APPLICATION ──────────────────────────────────────────────────────────────
APP_NAME=User Management System
APP_VERSION=1.0.0
# Set DEBUG=True in development to see SQL queries in console
DEBUG=False
